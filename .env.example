# Environment configuration for the payroll tax engine.
# Copy to `.env` (gitignored) and adjust as needed.

# MongoDB connection string. Defaults to this value if unset.
MONGO_URI=mongodb://localhost:27017/payroll

# Secret used to sign + verify tenant JWTs. Use a strong value in production.
JWT_SECRET=dev-secret

# HTTP port the API listens on.
PORT=3000
